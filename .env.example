# Google Cloud Service Account JSON credentials for Vision API and Sheets API
GOOGLE_APPLICATION_CREDENTIALS=./google-credentials.json

# OCR.space API Key (Get a free key from https://ocr.space/OCRAPI)
OCR_SPACE_API_KEY=your_ocr_space_api_key_here

# Google Sheet ID (From the URL of your Google Sheet)
# Example: https://docs.google.com/spreadsheets/d/YOUR_SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here

# OpenRouter API Key (For Nemotron Vision LLM)
OPENROUTER_API_KEY=your_openrouter_api_key_here
